# Example overlay for a small private single-map host.
# Copy values into .env; do not run Compose with this file by itself.

WORLD_NAME=My Private Dune Server
WORLD_UNIQUE_NAME=my-private-dune
WORLD_REGION=North America

# Use the address players can reach. For public-list joins from inside the LAN,
# keep this public and solve hairpin/LAN reflection at the router/firewall.
EXTERNAL_ADDRESS=203.0.113.10
GAME_RMQ_PUBLIC_HOST=203.0.113.10
GAME_RMQ_PUBLIC_PORT=31982

# Keep admin local unless a trusted LAN/VPN reverse proxy is in front.
DUNE_ADMIN_BIND_ADDRESS=127.0.0.1
DUNE_ADMIN_HOST_PORT=18080
DUNE_ADMIN_ALLOWED_HOSTS=127.0.0.1:18080,localhost:18080,admin.example.test,admin-panel:8080

# Conservative admin defaults for a new operator.
DUNE_ADMIN_MUTATIONS_ENABLED=false
DUNE_ADMIN_ITEM_GRANTS_ENABLED=false
DUNE_ADMIN_GM_COMMANDS_ENABLED=false
DUNE_CHAT_COMMAND_DRY_RUN=true
