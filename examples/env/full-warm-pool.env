# Example overlay for a 30-partition warm-pool host.
# Copy values into .env; do not run Compose with this file by itself.

WORLD_NAME=My Dune Warm Pool
WORLD_UNIQUE_NAME=my-dune-warm-pool
WORLD_REGION=North America

EXTERNAL_ADDRESS=203.0.113.10
GAME_RMQ_PUBLIC_HOST=203.0.113.10
GAME_RMQ_PUBLIC_PORT=31982
GAME_RMQ_BIND_ADDRESS=0.0.0.0

# Use the all-maps overlay with commands that accept COMPOSE_FILES.
COMPOSE_FILES=compose.yaml:compose.allmaps.yaml

# Daily maintenance scheduler and admin restart hook.
DUNE_ADMIN_RESTART_COMMAND=/workspace/scripts/restart-target.sh
DUNE_ADMIN_RESTART_COMMAND_TIMEOUT_SECONDS=1800
DUNE_RESTART_USE_HOST_COMPOSE=true
DUNE_RESTART_HOST_WORKSPACE=/path/to/DuneAwakeningSelfHost
DUNE_RESTART_COMPOSE_PROJECT=dune_server
DUNE_STEAM_SERVER_DIR=/path/to/Steam/steamapps/common/Dune Awakening Self-Hosted Server
DUNE_RESTART_CHECK_STEAM_UPDATE=true
DUNE_DAILY_RESTART_SCHEDULE_WINDOW=05:25-05:35
DUNE_DAILY_RESTART_ALLOW_OUTSIDE_WINDOW=false
DUNE_DAILY_RESTART_DELAY=30min
DUNE_DAILY_RESTART_REPEAT_SECONDS=600
DUNE_DAILY_RESTART_MESSAGE=Daily maintenance restart at 6:00 AM. Please get to a safe place.

# Optional watchdog recovery. Keep recovery false until status-only checks look
# correct on the new host.
DUNE_ADMIN_BOT_MAP_WATCHDOG_ENABLED=true
DUNE_ADMIN_BOT_MAP_WATCHDOG_RECOVER=false
