# Mirror local DASH backups from kspls0 back to kspld0 over SSH.
#
# This config is intended for a mirror-only timer. It does not create a local
# backup itself, so it is safe to run while the game stack is offline.

DUNE_BACKUP_OFFSITE_MODE=rsync
DUNE_BACKUP_RSYNC_DEST=192.168.50.148:/home/keith/Documents/code/DuneAwakeningSelfHost/backups/from-kspls0
DUNE_BACKUP_KEEP_LOCAL_DAYS=0
DUNE_BACKUP_KEEP_REMOTE_DAYS=0
DUNE_BACKUP_INCLUDE_MAINTENANCE=true
DUNE_BACKUP_CREATE_LOCAL=false
