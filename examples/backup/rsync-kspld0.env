# Mirror this host's DASH backups to kspld0 without creating a new local
# backup. The systemd mirror unit runs this after backup directory changes and
# hourly as a catch-up.

DUNE_BACKUP_OFFSITE_MODE=rsync
DUNE_BACKUP_RSYNC_DEST=keith@192.168.50.148:/home/keith/Documents/code/DuneAwakeningSelfHost/backups/from-kspls0
DUNE_BACKUP_KEEP_LOCAL_DAYS=0
DUNE_BACKUP_KEEP_REMOTE_DAYS=0
DUNE_BACKUP_INCLUDE_MAINTENANCE=true
DUNE_BACKUP_CREATE_LOCAL=false
RSYNC_RSH="ssh -o BatchMode=yes -o ConnectTimeout=10"
