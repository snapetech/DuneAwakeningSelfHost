# Example offsite backup settings for rclone.
# Source this file or copy values into the environment before running:
#   DUNE_BACKUP_REMOTE_ENV=examples/backup/rclone-offsite.env ./scripts/backup-offsite.sh .env

DUNE_BACKUP_OFFSITE_MODE=rclone
DUNE_BACKUP_RCLONE_DEST=proton:backups/snape.local/dune-awakening-selfhost
RCLONE_CONFIG=/home/keith/.config/rclone/rclone.conf
DUNE_BACKUP_KEEP_LOCAL_DAYS=7
DUNE_BACKUP_KEEP_REMOTE_DAYS=30
DUNE_BACKUP_INCLUDE_MAINTENANCE=true
DUNE_BACKUP_CREATE_LOCAL=true
