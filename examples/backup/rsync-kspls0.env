# Mirror this host's DASH backups to kspls0 without creating a new local
# backup. Use this as the remote config for dune-backup-mirror-peer.timer when
# kspld0 is the active gameserver primary.

DUNE_BACKUP_OFFSITE_MODE=rsync
DUNE_BACKUP_RSYNC_DEST=keith@192.168.50.85:/home/keith/Documents/code/DuneAwakeningSelfHost/backups/from-kspld0
DUNE_BACKUP_KEEP_LOCAL_DAYS=0
DUNE_BACKUP_KEEP_REMOTE_DAYS=0
DUNE_BACKUP_INCLUDE_MAINTENANCE=true
DUNE_BACKUP_CREATE_LOCAL=false
RSYNC_RSH="ssh -o BatchMode=yes -o ConnectTimeout=10"
