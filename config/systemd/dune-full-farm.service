[Unit]
Description=Dune full 30-map farm startup
After=docker.service network-online.target
Wants=network-online.target
Requires=docker.service

[Service]
Type=oneshot
WorkingDirectory=/opt/DuneAwakeningSelfHost
ExecStart=/opt/DuneAwakeningSelfHost/scripts/start-full-warm-pool.sh /opt/DuneAwakeningSelfHost/.env
RemainAfterExit=yes
TimeoutStartSec=1800

[Install]
WantedBy=multi-user.target
