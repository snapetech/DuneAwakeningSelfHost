      "requiredWhen": {"always": true},
      "minimumBytes": 16,
      "placeholders": ["change-me-fls-secret"],
      "rotationPolicy": "provider-managed",
      "maximumAgeDays": 180,
      "consumers": ["director", "gateway", "game maps"],
      "backup": {"type": "env-copy"},
      "documentation": "docs/configuration-durability.md"
    },
    {
