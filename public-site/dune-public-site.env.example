# Public Dune static site renderer configuration.
# Copy to /etc/dune-public-site.env or pass as an EnvironmentFile from systemd.

# Path to the DuneAwakeningSelfHost checkout that owns compose.yaml and .env.
DUNE_ROOT=/opt/DuneAwakeningSelfHost

# Optional: authoritative DASH game env file. Defaults to $DUNE_ROOT/.env.
# Keep game database and compose settings in the DASH .env, not in this file.
# ENV_FILE=/opt/DuneAwakeningSelfHost/.env

# Public web directory that contains index.html, style.css, and app.js.
STATIC_DIR=/srv/dash-public-site
INDEX_FILE=/srv/dash-public-site/index.html
STATUS_FILE=/srv/dash-public-site/status.html

# Public-facing page text.
PUBLIC_SITE_TITLE="Dune Awakening Server"
PUBLIC_SERVER_NAME="Dune Awakening Server"
PUBLIC_SERVER_DESCRIPTION="A community Dune Awakening server with public status, settings, and an active player map."
PUBLIC_SERVER_WHERE="Dune Awakening > Servers > search for your server name."
PUBLIC_STACK_URL=https://github.com/snapetech/DuneAwakeningSelfHost

# Optional federated public directory publication. The entry URL must be the
# exact HTTPS location where this site's directory-entry.json will be served.
# The Ed25519 private identity remains under DUNE_ROOT/config/secrets.
DUNE_PUBLIC_DIRECTORY_ENABLED=false
DUNE_PUBLIC_DIRECTORY_ENTRY_URL=
DUNE_PUBLIC_SITE_URL=
DUNE_PUBLIC_DIRECTORY_NAME=
DUNE_PUBLIC_DIRECTORY_DESCRIPTION=
DUNE_PUBLIC_DIRECTORY_REGION=North America
DUNE_PUBLIC_DIRECTORY_CAPACITY=40
DUNE_PUBLIC_DIRECTORY_DISCORD_INVITE=
DUNE_PUBLIC_DIRECTORY_TTL_SECONDS=180

# Optional: standby/static mirror host. Leave empty for single-host installs.
SYNC_HOST=
SYNC_STATIC_ROOT=/srv

# Optional: how long server health collection may run. Full-farm docker status
# can exceed 20s under load.
STATUS_TIMEOUT_SECONDS=60

# Hagga Basin map calibration.
DUNE_HAGGA_MAP_MIN_X=-457200
DUNE_HAGGA_MAP_MAX_X=355600
DUNE_HAGGA_MAP_MIN_Y=-457200
DUNE_HAGGA_MAP_MAX_Y=355600
DUNE_HAGGA_MAP_INVERT_X=false
DUNE_HAGGA_MAP_INVERT_Y=false
DUNE_HAGGA_MAP_IMAGE_MIN_U=0
DUNE_HAGGA_MAP_IMAGE_MAX_U=1
DUNE_HAGGA_MAP_IMAGE_MIN_V=0
DUNE_HAGGA_MAP_IMAGE_MAX_V=1
