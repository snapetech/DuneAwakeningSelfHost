# Public Dune static site renderer configuration.
# Copy to /etc/dune-public-site.env or pass as an EnvironmentFile from systemd.

# Path to the DuneAwakeningSelfHost checkout that owns compose.yaml and .env.
DUNE_ROOT=/opt/DuneAwakeningSelfHost

# Public web directory that contains index.html, style.css, and app.js.
STATIC_DIR=/srv/dash-public-site
INDEX_FILE=/srv/dash-public-site/index.html
STATUS_FILE=/srv/dash-public-site/status.html

# Database name inside the Dune Postgres container.
DUNE_DATABASE=dune_sb_1_4_0_0

# Optional: standby/static mirror host. Leave empty for single-host installs.
SYNC_HOST=
SYNC_STATIC_ROOT=/srv

# Optional: how long server health collection may run.
STATUS_TIMEOUT_SECONDS=20

# Hagga Basin map calibration. Defaults match the Snapetech deployment.
DUNE_HAGGA_MAP_MIN_X=-457200
DUNE_HAGGA_MAP_MAX_X=355600
DUNE_HAGGA_MAP_MIN_Y=-457200
DUNE_HAGGA_MAP_MAX_Y=355600
DUNE_HAGGA_MAP_INVERT_X=false
DUNE_HAGGA_MAP_INVERT_Y=false
DUNE_HAGGA_MAP_IMAGE_MIN_U=0
DUNE_HAGGA_MAP_IMAGE_MAX_U=1
DUNE_HAGGA_MAP_IMAGE_MIN_V=0
DUNE_HAGGA_MAP_IMAGE_MAX_V=1
