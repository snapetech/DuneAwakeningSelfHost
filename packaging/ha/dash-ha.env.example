# Installed as /etc/dash/ha.env or rendered directly into the health-check
# systemd/Keepalived environment. Rotate the epoch on every authority transfer.
DASH_HA_AUTHORITY_MARKER=/var/lib/dash/ha/active-authority.json
DASH_HA_EXPECTED_EPOCH=replace-with-unique-cutover-epoch
DASH_HA_SERVICE_UNIT=dash.service
