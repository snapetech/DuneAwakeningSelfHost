DUNE_STEAM_SERVER_DIR=/path/to/Steam/steamapps/common/Dune Awakening Self-Hosted Server
DUNE_IMAGE_TAG=1963158-0-shipping

WORLD_NAME=My Dune Awakening Server
WORLD_UNIQUE_NAME=sh-example-dune
WORLD_REGION=North America
DUNE_SERVER_LOGIN_PASSWORD=

# Paste the self-hosting/FLS token from Funcom's account page.
# Live account portal: https://account.duneawakening.com/
FLS_SECRET=

POSTGRES_SUPER_PASSWORD=change-me-postgres-super
POSTGRES_DUNE_PASSWORD=change-me-dune-db
RMQ_HTTP_TOKEN_AUTH_SECRET=change-me-rmq-secret

# Admin web panel. Keep bound to localhost or behind trusted LAN/VPN auth.
DUNE_ADMIN_TOKEN=change-me-admin-token
DUNE_ADMIN_MUTATIONS_ENABLED=false
DUNE_ADMIN_ITEM_GRANTS_ENABLED=true
DUNE_ADMIN_MAX_BODY_BYTES=65536
DUNE_ADMIN_AUDIT_MAX_BYTES=5242880
DUNE_ADMIN_REQUEST_TIMEOUT_SECONDS=10
DUNE_ADMIN_MAX_ITEM_STACK_SIZE=1000000
DUNE_ADMIN_AUDIT_EVENT_LIMIT=100
DUNE_ADMIN_REFERENCE_LIMIT=200
DUNE_ADMIN_CHARACTER_SEARCH_LIMIT=100
DUNE_ADMIN_BIND_ADDRESS=127.0.0.1
DUNE_ADMIN_HOST_PORT=18080
DUNE_ADMIN_ALLOWED_HOSTS=127.0.0.1:18080,localhost:18080,admin.example.test,admin-panel:8080
DUNE_ADMIN_ANNOUNCE_COMMAND=/workspace/scripts/announce.sh
DUNE_ADMIN_ANNOUNCEMENT_MAX_MESSAGE_BYTES=500
DUNE_ADMIN_ANNOUNCEMENT_COMMAND_TIMEOUT_SECONDS=10
DUNE_ANNOUNCE_RMQ_URL=http://admin-rmq:15672
DUNE_ANNOUNCE_RMQ_USER=bgd.<world-unique-name>.duneadmin.admin
DUNE_ANNOUNCE_RMQ_PASSWORD=change-me-announcer-password
DUNE_ANNOUNCE_RMQ_EXCHANGE=rpc
DUNE_ANNOUNCE_RMQ_ROUTING_KEYS=Survival_11
DUNE_ANNOUNCE_RMQ_REPLY_TO=bgdRpc
DUNE_ANNOUNCE_RMQ_CORRELATION_ID=
DUNE_ANNOUNCE_RMQ_TYPE=json_rpc
DUNE_ANNOUNCE_RMQ_APP_ID=
DUNE_ANNOUNCE_RMQ_USER_ID=
DUNE_ANNOUNCE_COMMAND_NAME=ServiceBroadcast
DUNE_ANNOUNCE_TITLE=Maintenance
DUNE_ANNOUNCE_DURATION_SECONDS=12
DUNE_ANNOUNCE_PAYLOAD_MODE=jsonrpc-notify-array
DUNE_ANNOUNCE_PAYLOAD_TEMPLATE=
DUNE_ADMIN_RESTART_COMMAND=/workspace/scripts/restart-target.sh
DUNE_ADMIN_RESTART_COMMAND_TIMEOUT_SECONDS=1800
DUNE_RESTART_COMPOSE_PROJECT=dune_server
DUNE_RESTART_DOCKER_SOCKET=/var/run/docker.sock

# Use the host/LAN IP clients should reach.
EXTERNAL_ADDRESS=127.0.0.1

# Client-facing game RabbitMQ address returned by FLS during login.
# For public/private live self-hosting this must resolve from player machines,
# not only from inside Docker.
GAME_RMQ_PUBLIC_HOST=127.0.0.1
GAME_RMQ_PUBLIC_PORT=31982
GAME_RMQ_BIND_ADDRESS=0.0.0.0
