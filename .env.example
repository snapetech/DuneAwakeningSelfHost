# Use the host/LAN IP clients should reach.
EXTERNAL_ADDRESS=127.0.0.1

# Optional dynamic public-IPv4 monitor. The hostname allowlist is mandatory so
# a copied .env cannot restart the wrong machine. Keep dry-run enabled through
# the first timer/check validation, then disable it to allow address changes.
DUNE_PUBLIC_IP_MONITOR_ENABLED=false
DUNE_PUBLIC_IP_MONITOR_ALLOWED_HOST=
DUNE_PUBLIC_IP_MONITOR_INTERVAL_MINUTES=5
DUNE_PUBLIC_IP_MONITOR_DRY_RUN=true
DUNE_PUBLIC_IP_MONITOR_DETECTED_IP=

# Additional Survival_1/Sietch dimensions. Mutations require both this gate and
# an exact short-hostname match; generated overlays/passwords live in backups.
DUNE_SIETCH_MUTATIONS_ENABLED=false
DUNE_SIETCH_ALLOWED_HOST=

# Client-facing game RabbitMQ address returned by FLS during login.
# For public/private live self-hosting this must resolve from player machines,
# not only from inside Docker.
GAME_RMQ_PUBLIC_HOST=127.0.0.1
GAME_RMQ_PUBLIC_PORT=31982
GAME_RMQ_PUBLIC_HTTP_PORT=15673
GAME_UDP_PORT_RANGE=7777:7810
IGW_UDP_PORT_RANGE=7888:7918
GAME_RMQ_BIND_ADDRESS=0.0.0.0
GAME_RMQ_HTTP_BIND_ADDRESS=127.0.0.1

# Compatibility rollback: set true to force IGW server-to-server bind
# advertisement to the container POD_IP on next game-server restart.
DUNE_FORCE_PRIVATE_IGW_BIND_ADDRESS=false
DUNE_DISABLE_MULTIHOME=false
