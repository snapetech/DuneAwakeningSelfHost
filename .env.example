DUNE_ANNOUNCE_GAME_RMQ_AMQP_PORT=31982
DUNE_ANNOUNCE_GAME_RMQ_AMQP_TLS=true
DUNE_ANNOUNCE_HTTP_TIMEOUT_SECONDS=0.5
DUNE_ANNOUNCE_ALLOW_MANAGEMENT_PUBLISH=false
