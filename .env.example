DUNE_PLAYER_PRESENCE_VERMILIUS_GAP_TEMPLATE=Congrats! {playername} has outrun Shai-Hulud!

# Portable backup sync helper. Leave mode as none until the selected tool is
# configured and tested manually. Example configs live under examples/backup/.
DUNE_BACKUP_OFFSITE_MODE=none
DUNE_BACKUP_REMOTE_ENV=
DUNE_BACKUP_CREATE_LOCAL=true
DUNE_BACKUP_INCLUDE_MAINTENANCE=true
DUNE_BACKUP_KEEP_LOCAL_DAYS=7
DUNE_BACKUP_KEEP_REMOTE_DAYS=30
DUNE_BACKUP_RCLONE_DEST=
DUNE_BACKUP_RSYNC_DEST=
DUNE_BACKUP_RESTIC_TAGS=dash,dune,self-host
DUNE_BACKUP_RESTIC_KEEP_DAILY=14
DUNE_BACKUP_RESTIC_KEEP_WEEKLY=8
DUNE_BACKUP_RESTIC_KEEP_MONTHLY=6

# Artificial Exchange buyer. V1 is dry-run first and leaves seller settlement
# as an observed report until native retrieve semantics are validated.
DUNE_ARTIFICIAL_EXCHANGE_ENABLED=true
DUNE_ARTIFICIAL_EXCHANGE_DRY_RUN=true
