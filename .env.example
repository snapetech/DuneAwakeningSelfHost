DUNE_STEAM_SERVER_DIR=/path/to/Steam/steamapps/common/Dune Awakening Self-Hosted Server
DUNE_IMAGE_TAG=1963158-0-shipping

WORLD_NAME=My Dune Awakening Server
WORLD_UNIQUE_NAME=sh-example-dune
WORLD_REGION=North America
DUNE_SERVER_DISPLAY_NAME=
DUNE_SERVER_LOGIN_PASSWORD=

# Paste the self-hosting/FLS token from Funcom's account page.
# Live account portal: https://account.duneawakening.com/
FLS_SECRET=

POSTGRES_SUPER_PASSWORD=change-me-postgres-super
POSTGRES_DUNE_PASSWORD=change-me-dune-db
POSTGRES_REPLICATION_USER=dune_replicator
POSTGRES_REPLICATION_PASSWORD=change-me-replication-password
POSTGRES_REPLICATION_SLOT=dune_standby
POSTGRES_REPLICA_HOST_PORT=15433
POSTGRES_REPLICATION_BIND_ADDRESS=127.0.0.1
POSTGRES_REPLICATION_ALLOWED_ADDRESS=
POSTGRES_REPLICATION_PRIMARY_HOST=127.0.0.1
POSTGRES_REPLICATION_PUBLIC_PORT=15434
POSTGRES_REMOTE_REPLICATION_SLOT=dune_standby_remote
POSTGRES_REMOTE_REPLICA_HOST=
POSTGRES_REMOTE_REPLICA_ROOT=/srv/dune-postgres-replica
POSTGRES_REMOTE_REPLICA_HOST_PORT=
DUNE_REPLICA_SNAPSHOT_KEEP_HOURS=48
RMQ_HTTP_TOKEN_AUTH_SECRET=change-me-rmq-secret

# Admin web panel. Keep bound to localhost or behind trusted LAN/VPN auth.
DUNE_ADMIN_TOKEN=change-me-admin-token
DUNE_ADMIN_MUTATIONS_ENABLED=true
DUNE_ADMIN_ITEM_GRANTS_ENABLED=true
DUNE_ADMIN_GM_COMMANDS_ENABLED=false
DUNE_ADMIN_CATALOG_ENABLED=true
DUNE_ADMIN_TYPED_KNOBS_ENABLED=false
