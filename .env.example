DUNE_ADMIN_BUNDLE_MUTATIONS_ENABLED=false
DUNE_ADMIN_REPUTATION_MUTATIONS_ENABLED=false
DUNE_ADMIN_JOURNEY_MUTATIONS_ENABLED=false
DUNE_ADMIN_MAX_BODY_BYTES=65536
DUNE_ADMIN_AUDIT_MAX_BYTES=5242880
DUNE_ADMIN_REQUEST_TIMEOUT_SECONDS=10
DUNE_ADMIN_MAX_ITEM_STACK_SIZE=1000000
DUNE_ADMIN_AUDIT_EVENT_LIMIT=100
DUNE_ADMIN_REFERENCE_LIMIT=200
DUNE_ADMIN_CHARACTER_SEARCH_LIMIT=100
DUNE_ADMIN_STEAM_PROFILE_CACHE_TTL_SECONDS=86400
DUNE_ADMIN_STEAM_PROFILE_LOOKUP_ENABLED=true
DUNE_ADMIN_BIND_ADDRESS=127.0.0.1
DUNE_ADMIN_HOST_PORT=18080
DUNE_ADMIN_ALLOWED_HOSTS=127.0.0.1:18080,localhost:18080,admin.example.test,admin-panel:8080
DUNE_HAGGA_MAP_MIN_X=-457200
DUNE_HAGGA_MAP_MAX_X=355600
DUNE_HAGGA_MAP_MIN_Y=-457200
DUNE_HAGGA_MAP_MAX_Y=355600
DUNE_HAGGA_MAP_INVERT_X=false
DUNE_HAGGA_MAP_INVERT_Y=false
DUNE_HAGGA_MAP_IMAGE_MIN_U=0
DUNE_HAGGA_MAP_IMAGE_MAX_U=1
DUNE_HAGGA_MAP_IMAGE_MIN_V=0
DUNE_HAGGA_MAP_IMAGE_MAX_V=1
DUNE_HAGGA_MAP_SHOW_RETURN_POINTS=false
# Optional LAN reverse-proxy probe. Keep the hostname private to LAN/VPN.
DUNE_ADMIN_LAN_URL=
DUNE_ADMIN_ANNOUNCE_COMMAND=/workspace/scripts/announce.sh
DUNE_ADMIN_ANNOUNCEMENT_MAX_MESSAGE_BYTES=500
DUNE_ADMIN_ANNOUNCEMENT_COMMAND_TIMEOUT_SECONDS=45
