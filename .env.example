DUNE_STEAM_SERVER_DIR=/path/to/Steam/steamapps/common/Dune Awakening Self-Hosted Server
DUNE_IMAGE_TAG=1968181-0-shipping

WORLD_NAME=My 24/7 PvE Dune Awakening Server
WORLD_UNIQUE_NAME=sh-example-dune
WORLD_REGION=North America
WORLD_DATACENTER_ID=North America
DUNE_FLS_ENV=retail
DUNE_SERVER_DISPLAY_NAME=Friendly PvE, community rules, active admins
DUNE_SERVER_LOGIN_PASSWORD=
# Optional Unreal startup console commands appended by scripts/run_server_safe.sh.
# This is evaluated when game-server containers start; it does not affect an
# already-running map process.
DUNE_SERVER_STARTUP_EXECCMDS=

# Build-specific runtime patch for immediate logout/logoff timers. The INI
# reconnect-grace values are not enough for unsafe-location logout waits in the
# current build. restart-post-start-health.sh reapplies this after map restarts.
DUNE_LOGOFF_TIMER_RUNTIME_PATCH_ENABLED=true
DUNE_LOGOFF_TIMER_CONTAINERS=dune_server-survival-1 dune_server-deep-desert-1 dune_server-deep-desert-pvp-1
DUNE_LAN_REFLECTION_REFRESH_AFTER_START=true
# Stable Linux interface for the Compose network. Keep within Linux's 15-character limit.
DUNE_DOCKER_BRIDGE_NAME=dune-br0

# Experimental repo-owned subfief/totem count knob. The game appears to use a
# base limit of 3 plus DunePlayerCharacterAttributeSet.SubfiefLimitBonus.
# Apply to persisted player actors and install/update the DB trigger with:
#   ./scripts/apply-subfief-limit-knob.sh .env
DUNE_SUBFIEF_LIMIT=6
DUNE_SUBFIEF_BASE_LIMIT=3
# Optional direct bonus override. If set, this wins over DUNE_SUBFIEF_LIMIT.
# DUNE_SUBFIEF_LIMIT_BONUS=6 makes the likely total 9 when the base is 3.
DUNE_SUBFIEF_LIMIT_BONUS=
# Presence automation quietly repairs joined/rejoined players whose current
# pawn has a missing or lower SubfiefLimitBonus. Leave MIN_BONUS empty to use
# DUNE_SUBFIEF_LIMIT_BONUS, or DUNE_SUBFIEF_LIMIT - DUNE_SUBFIEF_BASE_LIMIT.
DUNE_PLAYER_PRESENCE_SUBFIEF_BONUS_ENFORCER_ENABLED=true
DUNE_PLAYER_PRESENCE_SUBFIEF_MIN_BONUS=

# Cooked pak patch for the BuildingPiece structure-category limit.
# Requires an Oodle shared library mounted inside each opted-in game container.
DUNE_BUILDING_PIECE_LIMIT_PATCH_ENABLED=true
DUNE_BUILDING_PIECE_LIMIT=10000
DUNE_LANDSRAAD_VENDOR_FACTION_GATE_PATCH_ENABLED=false
# Experimental binary patch that raises the per-player subfief/totem placement cap.
# Requires the sigscan signature to be populated in scripts/patch-subfief-cap-binary.py
# from Ghidra analysis. Keep disabled until validated in handoff lab.
DUNE_SUBFIEF_CAP_BINARY_PATCH_ENABLED=true
DUNE_SUBFIEF_CAP_BINARY_TARGET=all
DUNE_SUBFIEF_CAP=6
# Experimental Deep Desert BRT enablement patches. The buildable-region patch
# swaps the cooked DeepDesert/HaggaBasin table rows inside DD containers only.
DUNE_BRT_DD_INVALID_MAP_BINARY_PATCH_ENABLED=false
DUNE_BRT_DD_ACTION_GATE_BINARY_PATCH_ENABLED=false
DUNE_BRT_DD_BUILDABLE_MAP_REGION_PATCH_ENABLED=false
DUNE_BRT_DD_BUILDABLE_MAP_REGION_PATCH_MODE=dd-totem-groups
DUNE_BRT_DD_BUILDABLE_MAP_REGION_OVERLAY_PAK=/home/dune/server/DuneSandbox/Content/Paks/zzz_brt_dd_buildable_map_region_patch.pak
DUNE_BRT_DD_NARROW_TOOL_STATE_BINARY_PATCH_ENABLED=false
DUNE_BRT_DD_NARROW_TOOL_STATE_PATCH_SITES=can-use-empty-context,state-empty-context,failure-reason-action-method,can-use-region-fail-join
DUNE_BRT_DD_TOOL_ENABLE_BINARY_PATCH_ENABLED=false
# Experimental native Linux server-process preload hook. This is for lab
# validation of an injected server-side runtime, not for Dune client mods.
DUNE_ENABLE_LINUX_SERVER_PRELOAD=false
DUNE_LINUX_SERVER_PRELOAD=/workspace/build/linux-server-loader/libdune_server_probe_loader.so
DUNE_LINUX_SERVER_PRELOAD_PARTITIONS=
DUNE_PROBE_LOADER_LOG=/tmp/dune-server-probe-loader.log
DUNE_PROBE_LOADER_SNAPSHOT_DELAY_SECONDS=0
DUNE_PROBE_LOADER_UE_DELAYED_PROBE_SECONDS=0
DUNE_PROBE_LOADER_UE_OBJECT_ARRAY_CLASS_REFLECTION_PROBE=false
DUNE_PROBE_LOADER_UE_OBJECT_ARRAY_CLASS_REFLECTION_MAX=32
DUNE_PROBE_LOADER_UE_PROCESS_EVENT_VTABLE_SCAN=false
DUNE_PROBE_LOADER_UE_PROCESS_EVENT_VTABLE_SCAN_SLOTS=96
DUNE_PROBE_LOADER_UE_PROCESS_EVENT_HOOK_IMAGE_OFFSET=
DUNE_PROBE_LOADER_UE_PROCESS_EVENT_IMAGE_OFFSET=
DUNE_PROBE_LOADER_UE_PROCESS_EVENT_LIVE_HOOK_IMAGE_OFFSET=
DUNE_PROBE_LOADER_UE_PROCESS_EVENT_ACTIVE_VALIDATE=false
DUNE_PROBE_LOADER_UE_PROCESS_EVENT_ACTIVE_VALIDATE_ALLOW_NATIVE_CALL=false
DUNE_PROBE_LOADER_UE_PROCESS_EVENT_ACTIVE_VALIDATE_THROUGH_TARGET=false
DUNE_PROBE_LOADER_UE_PROCESS_EVENT_ACTIVE_VALIDATE_SUPPRESS_ORIGINAL=false
DUNE_PROBE_LOADER_UE_PROCESS_EVENT_ACTIVE_VALIDATE_OBJECT_ADDRESS=
DUNE_PROBE_LOADER_UE_PROCESS_EVENT_ACTIVE_VALIDATE_OBJECT_PATH=
DUNE_PROBE_LOADER_UE_PROCESS_EVENT_ACTIVE_VALIDATE_OBJECT_NAME=
DUNE_PROBE_LOADER_UE_PROCESS_EVENT_ACTIVE_VALIDATE_FUNCTION_ADDRESS=
DUNE_PROBE_LOADER_UE_PROCESS_EVENT_ACTIVE_VALIDATE_FUNCTION_PATH=
DUNE_PROBE_LOADER_UE_PROCESS_EVENT_ACTIVE_VALIDATE_PARAMS_ADDRESS=
DUNE_PROBE_LOADER_UE_CALL_FUNCTION_HOOK_IMAGE_OFFSET=
DUNE_PROBE_LOADER_UE_CALL_FUNCTION_IMAGE_OFFSET=
DUNE_PROBE_LOADER_UE_CALL_FUNCTION_LIVE_HOOK_IMAGE_OFFSET=
DUNE_PROBE_LOADER_UE_CALL_FUNCTION_ACTIVE_VALIDATE=false
DUNE_PROBE_LOADER_UE_CALL_FUNCTION_ACTIVE_VALIDATE_ALLOW_NATIVE_CALL=false
DUNE_PROBE_LOADER_UE_CALL_FUNCTION_ACTIVE_VALIDATE_THROUGH_TARGET=false
DUNE_PROBE_LOADER_UE_CALL_FUNCTION_ACTIVE_VALIDATE_OBJECT_ADDRESS=
DUNE_PROBE_LOADER_UE_CALL_FUNCTION_ACTIVE_VALIDATE_COMMAND=
DUNE_PROBE_LOADER_UE_CALL_FUNCTION_ACTIVE_VALIDATE_COMMAND_ADDRESS=
DUNE_PROBE_LOADER_UE_CALL_FUNCTION_ACTIVE_VALIDATE_OUTPUT_ADDRESS=
DUNE_PROBE_LOADER_UE_CALL_FUNCTION_ACTIVE_VALIDATE_EXECUTOR_ADDRESS=
DUNE_PROBE_LOADER_UE_CALL_FUNCTION_ACTIVE_VALIDATE_FORCE_CALL=true
DUNE_PROBE_LOADER_UE_FNAME_ALLOW_MISSING_NONE=false
DUNE_PROBE_LOADER_UE_FNAME_DIAGNOSTICS=false
DUNE_PROBE_LOADER_UE_FNAME_DIAGNOSTICS_MAX=16
DUNE_PROBE_LOADER_SCAN_ENABLED=false
DUNE_PROBE_LOADER_SCAN_PRESETS=building,brt,deep-desert,gm,cheat
DUNE_PROBE_LOADER_SCAN_STRINGS=
DUNE_PROBE_LOADER_SCAN_SIGNATURES=
DUNE_PROBE_LOADER_SCAN_PATH_FILTER=
DUNE_PROBE_LOADER_SCAN_LOG_MAPPINGS=false
DUNE_PROBE_LOADER_SCAN_MAX_HITS_PER_NEEDLE=16
DUNE_PROBE_LOADER_SCAN_MAX_MAPPING_BYTES=536870912
# Optional Landsraad term-length tuning. If enabled, the active term is moved to
# start_time + DUNE_LANDSRAAD_TERM_LENGTH_DAYS rounded up to the next Coriolis
# boundary. Do not use unaligned end times; Landsraad period state is derived
# from Coriolis timing and can suspend globally when the DB term ends between
# Coriolis boundaries. Execute mode is host-guarded to kspls0 by default.
DUNE_LANDSRAAD_TERM_LENGTH_TUNING_ENABLED=false
DUNE_LANDSRAAD_TERM_LENGTH_DAYS=7
DUNE_LANDSRAAD_TERM_LENGTH_ALIGN_TO_CORIOLIS=true
DUNE_LANDSRAAD_TERM_LENGTH_CORIOLIS_CONFIG=config/UserGame.ini
DUNE_LANDSRAAD_TERM_LENGTH_REQUIRE_HOST=kspls0
# Pins Landsraad house tile goals at term creation and applies the same
# idempotent target to the current term during restart pre-start hygiene.
# Keep this at 25,000 so future stock goal changes do not compound.
DUNE_LANDSRAAD_GOAL_TUNING_ENABLED=false
DUNE_LANDSRAAD_GOAL_TARGET=25000
DUNE_LANDSRAAD_GOAL_SCALE=0.35714285714285714285
DUNE_LANDSRAAD_GOAL_MIN=1
DUNE_LANDSRAAD_GOAL_REQUIRE_HOST=kspls0
# Checks restart pre-start hygiene for an active Landsraad term that has tasks
# but missed the first reveal, then uses the first-party reveal function to
# unblock day-one missions. Execute mode skips unless the host is kspls0.
DUNE_LANDSRAAD_REVEAL_WATCHDOG_ENABLED=true
DUNE_LANDSRAAD_REVEAL_WATCHDOG_REQUIRE_HOST=kspls0
DUNE_LANDSRAAD_REVEAL_WATCHDOG_MIN_AGE_MINUTES=5
DUNE_LANDSRAAD_REVEAL_WATCHDOG_REQUIRED_TASK_COUNT=25
# Verifies Standard PvE DD keeps a weekly Coriolis cycle for Landsraad while
# leaving Coriolis damage, shifting sands, cycle restart, and DB wipe disabled.
DUNE_LANDSRAAD_CORIOLIS_GUARD_ENABLED=true
DUNE_LANDSRAAD_CORIOLIS_REQUIRED_CYCLE_DAYS=7
DUNE_LANDSRAAD_TERM_CORIOLIS_ALIGNMENT_GUARD_ENABLED=true
DUNE_LANDSRAAD_TERM_ALIGNMENT_TOLERANCE_SECONDS=300
DUNE_OODLE_LIBRARY=/tmp/oodle/liboodle-data-shared.so

# Paste the self-hosting/FLS token from Funcom's account page.
# Live account portal: https://account.duneawakening.com/
FLS_SECRET=

POSTGRES_SUPER_PASSWORD=change-me-postgres-super
POSTGRES_DUNE_PASSWORD=change-me-dune-db
# Active Funcom game-schema database. Keep every admin/automation client on
# this exact value after an official schema migration.
DUNE_GAME_DB_NAME=dune_sb_1_4_0_0
POSTGRES_REPLICATION_USER=dune_replicator
POSTGRES_REPLICATION_PASSWORD=change-me-replication-password
POSTGRES_REPLICATION_SLOT=dune_standby
POSTGRES_REPLICA_HOST_PORT=15433
POSTGRES_REPLICATION_BIND_ADDRESS=127.0.0.1
POSTGRES_REPLICATION_ALLOWED_ADDRESS=
POSTGRES_REPLICATION_PRIMARY_HOST=127.0.0.1
POSTGRES_REPLICATION_PUBLIC_PORT=15434
POSTGRES_REMOTE_REPLICATION_SLOT=dune_standby_remote
POSTGRES_REMOTE_REPLICA_HOST=
POSTGRES_REMOTE_REPLICA_ROOT=/srv/dune-postgres-replica
POSTGRES_REMOTE_REPLICA_HOST_PORT=
DUNE_POSTGRES_STANDBY_NETWORK_MODE=bridge
# Leave COMPOSE_FILES unset for normal operations. scripts/compose-files.sh
# derives the active overlay set from POSTGRES_REMOTE_REPLICA_HOST, this host,
# and feature flags such as DUNE_BUILDING_PIECE_LIMIT_PATCH_ENABLED. The
# FLS IPv4 host pin overlay is included by default; set this false only after
# confirming the host has working IPv6 to Funcom FLS.
DUNE_FLS_IPV4_HOSTS_ENABLED=true
# Some live hosts can reach FLS from host networking while the Docker bridge
# path hangs. Enable this only when Director FLS publication fails from the
# bridge network; the port overlay must choose a free host-local port.
DUNE_DIRECTOR_HOSTNET_ENABLED=false
DUNE_DIRECTOR_HOSTNET_PORT_COMPOSE_FILE=compose.director-hostnet-port.yaml
# COMPOSE_FILES=
DUNE_CPU_AFFINITY_ENABLED=false
DUNE_CPU_AFFINITY_COMPOSE_FILE=compose.cpu-affinity.yaml
# Foreground defaults to survival, overmap, and both Deep Desert service names.
# The generator automatically prefers the largest shared-L3 domain (useful on
# X3D/hybrid hosts) and keeps infrastructure/optional maps in a background pool.
DUNE_CPU_AFFINITY_FOREGROUND_SERVICES=survival,overmap,deep-desert,deep-desert-pvp
DUNE_CPU_AFFINITY_FOREGROUND_CPUSET=
DUNE_CPU_AFFINITY_BACKGROUND_CPUSET=
DUNE_HOST_TUNING_ENABLED=false
DUNE_HOST_TUNING_THP_MODE=never
DUNE_HOST_TUNING_NIC_ENABLED=false
DUNE_HOST_TUNING_NIC=
DUNE_HOST_TUNING_NIC_IRQ_CPUSET=
DUNE_POSTGRES_STANDBY_TARGET_HOST=
DUNE_POSTGRES_STANDBY_TARGET_ROOT=
DUNE_POSTGRES_STANDBY_SLOT=
DUNE_POSTGRES_FAILOVER_SEAL_FILE=
DUNE_POSTGRES_FAILOVER_SEAL_DIR=backups/failover-seals
DUNE_REPLICA_SNAPSHOT_KEEP_HOURS=48
# Host that currently owns the live game service. After a promotion or cutover,
# update these with scripts/set-active-gameserver.sh so current, primary,
# standby, and Postgres replication direction values move together.
DUNE_CURRENT_HOST=
DUNE_CURRENT_LAN_IP=
DUNE_FAILOVER_PRIMARY_HOST=
DUNE_FAILOVER_PRIMARY_LAN_IP=
DUNE_FAILOVER_STANDBY_HOST=
DUNE_FAILOVER_STANDBY_LAN_IP=
DUNE_FAILOVER_ROUTER_SSH=
DUNE_FAILOVER_PUBLIC_IP=
DUNE_STANDBY_REPO_ROOT=
DUNE_STANDBY_ROLE_SERVICES=dune-full-farm.service dune-lan-reflection.service dune-map-watchdog.service dune-player-presence-announcer.service dune-artificial-exchange-bot.service dune-postgres-replication-forwarder.service
DUNE_STANDBY_ROLE_TIMERS=dune-backup-mirror-peer.timer dune-replica-snapshot.timer dune-daily-maintenance-schedule.timer dune-backup-restore-drill.timer
DUNE_STANDBY_WEBSITE_SERVICES=dune-status.service render-dune-static-status.service
DUNE_STANDBY_WEBSITE_TIMERS=render-dune-static-status.timer
# follow-role moves these units with the game primary. independent leaves the
# live static/status site wherever web routing currently points.
DUNE_STANDBY_WEBSITE_MODE=independent
DUNE_STANDBY_KEEP_WEBSITE_RUNNING=true
DUNE_STATUS_ROOT=
DUNE_STATUS_USER=
DUNE_STATUS_HOST=127.0.0.1
DUNE_STATUS_PORT=3030
DUNE_STANDBY_EXTRA_SYNC_PATHS=
DUNE_RMQ_TLS_RECREATE_SERVICES=game-rmq gateway director text-router survival overmap arrakeen harko-village testing-hephaestus testing-carthag testing-waterfat deep-desert proces-verbal lostharvest-ecolab-a lostharvest-ecolab-b lostharvest-forgottenlab art-of-kanly dungeon-hephaestus dungeon-oldcarthag faction-outpost-atre faction-outpost-hark heighliner-dungeon ecolab-green-089 ecolab-green-152 ecolab-green-024 ecolab-green-136 ecolab-green-195 overland-m-01 overland-s-04 overland-s-06 bandit-fortress overland-s-07 overland-s-08 dungeon-thepit
RMQ_HTTP_TOKEN_AUTH_SECRET=change-me-rmq-secret

